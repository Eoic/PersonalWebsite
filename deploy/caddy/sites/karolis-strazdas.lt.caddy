karolis-strazdas.lt, www.karolis-strazdas.lt {
	tls /etc/ssl/cloudflare-origin/karolis-strazdas.lt.pem /etc/ssl/cloudflare-origin/karolis-strazdas.lt.key

	@www host www.karolis-strazdas.lt
	redir @www https://karolis-strazdas.lt{uri} permanent

	reverse_proxy 127.0.0.1:8000 {
		header_up Host {host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
